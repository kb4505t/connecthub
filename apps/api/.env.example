# --- Server ---
NODE_ENV=development
PORT=4000

# --- Database (Supabase PostgreSQL connection string) ---
# DATABASE_URL: pooled connection (port 6543, via Supabase's pgbouncer) — used by the running app.
# DIRECT_URL: direct connection (port 5432) — used only by `prisma migrate`/`prisma db push`,
#             since migrations can't run through a connection pooler.
# For local Docker Postgres (docker-compose), both can point to the same URL.
DATABASE_URL="postgresql://connecthub:connecthub_dev_password@localhost:5432/connecthub"
DIRECT_URL="postgresql://connecthub:connecthub_dev_password@localhost:5432/connecthub"

# --- Supabase ---
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_ANON_KEY="your-anon-key"

# --- JWT ---
# Generate strong secrets, e.g.: openssl rand -base64 48
JWT_ACCESS_SECRET="replace-with-a-strong-random-secret-at-least-32-chars"
JWT_REFRESH_SECRET="replace-with-a-different-strong-random-secret-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# --- CORS ---
CLIENT_URL="http://localhost:3000"

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
